{
  "version": 4,
  "configurations": [
    {
      "name": "Win32",
      "includePath": [
        "${workspaceFolder}",
        "${workspaceFolder}/**"
      ],
      "intelliSenseMode": "windows-gcc-x86",
      "compilerPath": "C:/MinGW/bin/gcc.exe",
      "cStandard": "c17",
      "browse": {
        "path": [
          "${workspaceFolder}",
          "${workspaceFolder}/**"
        ],
        "limitSymbolsToIncludedHeaders": false
      }
    }
  ]
}
