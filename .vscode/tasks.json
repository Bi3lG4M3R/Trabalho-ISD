{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build C project",
      "type": "shell",
      "command": "gcc",
      "args": [
        "-Wall",
        "-Wextra",
        "-g3",
        "main.c",
        "funcoes.c",
        "-o",
        "output/main.exe"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}